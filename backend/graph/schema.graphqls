enum JobState {
  PENDING
  ANALYZING
  GENERATING
  COMPLETED
  FAILED
}

type Job {
  id: ID!
  name: String!
  status: JobState!
}

type Query {
  jobs: [Job!]!
}

type Mutation {
  createJob(name: String!): Job!
  updateJobStatus(id: ID!, status: JobState!): Job!
}

type Subscription {
  jobStatuses: [Job!]!
}
